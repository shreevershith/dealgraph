# ── DealGraph — Environment Variables ─────────────────────────────────────────

# ── LLM Provider (pick ONE) ──────────────────────────────────────────────────
# Options: ollama | groq | together | openai
LLM_PROVIDER=ollama

# Ollama (local dev — default)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.3

# Groq (recommended for deployment — free tier, hosts Llama 3.3 70B)
# Get your free API key at https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Together.ai (alternative — hosts many open-source models)
# TOGETHER_API_KEY=...
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct

# OpenAI (if you want GPT-4o instead)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Tavily Web Search (REQUIRED for full pipeline) ──────────────────────────
# Powers the WebResolver for verifying dynamic claims (market size, traction, etc.)
# Free tier: 1000 searches/month — https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Memgraph (OPTIONAL — graph DB for cached knowledge) ─────────────────────
# When set, factual_static claims are verified against the graph first.
# When unset, the pipeline works fine using web search only.
# MEMGRAPH_URI=bolt://localhost:7687
# MEMGRAPH_USER=
# MEMGRAPH_PASSWORD=

# ── edge-tts (free TTS voice) ───────────────────────────────────────────────
EDGE_TTS_VOICE=en-US-GuyNeural

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Telemetry (OPTIONAL) ─────────────────────────────────────────────────────
# SigNoz (APM / distributed tracing via OpenTelemetry)
# Set OTEL_EXPORTER_OTLP_TRACES_ENDPOINT to enable. SigNoz Cloud: https://ingest.<region>.signoz.cloud:443
# OTEL_SERVICE_NAME=dealgraph-backend
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://ingest.us.signoz.cloud:443
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_EXPORTER_OTLP_HEADERS=signoz-ingestion-key=<your-ingestion-key>

# Langfuse (LLM observability — traces Groq/Together/OpenAI calls)
# Get keys at https://cloud.langfuse.com (or self-host). Patch runs at startup when LANGFUSE_SECRET_KEY is set.
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
