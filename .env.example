# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  DealGraph — Environment Variables                                          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── LLM Provider (pick ONE) ──────────────────────────────────────────────────
# Options: ollama | groq | together | openai
LLM_PROVIDER=ollama

# Ollama (local dev — default)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.3

# Groq (recommended for deployment — free tier, hosts Llama 3.3 70B)
# Get your free API key at https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Together.ai (alternative — hosts many open-source models)
# TOGETHER_API_KEY=...
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct

# OpenAI (if you want GPT-4o instead)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Memgraph (self-hosted graph DB — replaces Neo4j AuraDB) ─────────────────
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# ── edge-tts (free TTS voice — replaces MiniMax) ────────────────────────────
EDGE_TTS_VOICE=en-US-GuyNeural

# ── CopilotKit (open source, self-hosted — no API key needed) ────────────────
# The backend's /copilotkit endpoint IS the runtime. No cloud key required.

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  HACKATHON BUILD — Original cloud service credentials (no longer needed)   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2
# NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
# MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=
# DD_API_KEY=
# DD_SITE=datadoghq.com
